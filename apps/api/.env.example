DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:5432/<db_name>
REDIS_URL=redis://<redis_host>:6379/0
RQ_QUEUE_NAME=pdf_jobs
CORS_ORIGINS=http://localhost:3000

AWS_ACCESS_KEY_ID=<aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
AWS_REGION=us-east-1
S3_BUCKET=<private_s3_bucket_name>
S3_ENDPOINT_URL=
S3_PRESIGNED_EXPIRES_SECONDS=3600

MAX_PDF_PAGES=100
MAX_UPLOAD_MB=100
PDF_RENDER_DPI=200
LOCAL_WORK_DIR=/tmp/handwritten-pdf-jobs

OPENAI_API_KEY=<openai_api_key>
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=png

FINAL_A4_WIDTH_PX=2480
FINAL_A4_HEIGHT_PX=3508
FINAL_PRINT_DPI=300
