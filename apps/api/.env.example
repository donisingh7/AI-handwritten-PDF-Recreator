PREMIUM_REMOVE_SOURCE_SCAN_MARKS=true
PREMIUM_SOURCE_BACKGROUND_WHITEN=true
PREMIUM_SOURCE_LINE_REMOVAL_STRENGTH=strong
PREMIUM_FORCE_PLAIN_A4=true
PREMIUM_FORCE_PURE_WHITE_BACKGROUND=true
PREMIUM_HEADING_INK_COLOR=black
PREMIUM_BODY_INK_COLOR=blue
PREMIUM_DIAGRAM_INK_COLOR=blue_black
PREMIUM_STYLE_RETRY_ON_FAIL=true
PREMIUM_MAX_STYLE_RETRIES=1
PREMIUM_OUTPUT_CLEANUP_ENABLED=true
PREMIUM_OUTPUT_FORCE_WHITE_BACKGROUND=true
PREMIUM_OUTPUT_REMOVE_RESIDUAL_LINES=true
PREMIUM_OUTPUT_DESPECKLE=true
PREMIUM_OUTPUT_PRESERVE_BLUE_BLACK_ONLY=true
